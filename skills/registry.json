                      "producers":  [
                                        "ludots-video-frame-extract"
                                    ],
                      "consumers":  [
                                        "ludots-cloud-handoff",
                                        "ludots-pr-issue-orchestration",
                                        "ludots-ci-audit-gate",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "visual.review.blocked",
                      "description":  "Visual review could not complete because evidence or criteria were insufficient within budget.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-visual-review"
                                    ],
                      "consumers":  [
                                        "ludots-feature-delivery",
                                        "ludots-cloud-handoff",
                                        "ludots-pr-issue-orchestration",
                                        "ludots-ci-audit-gate",
                                        "ludots-hook-orchestrator"
                                    ]
                  }
