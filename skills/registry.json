{
    "schema_version":  1,
    "ssot_root":  "skills",
    "flatten_on_install":  true,
    "install_targets":  {
                            "codex":  "$HOME/.codex/skills",
                            "claude":  "$HOME/.claude/skills"
                        },
    "contracts":  {
                      "hook_packet":  "skills/contracts/hook.schema.json",
                      "evidence_manifest":  "skills/contracts/evidence-manifest.schema.json",
                      "review_result":  "skills/contracts/review-result.schema.json"
                  },
    "layers":  [
                   {
                       "id":  "governance",
                       "path":  "skills/governance"
                   },
                   {
                       "id":  "collaboration",
                       "path":  "skills/collaboration"
                   },
                   {
                       "id":  "delivery",
                       "path":  "skills/delivery"
                   },
                   {
                       "id":  "evidence",
                       "path":  "skills/evidence"
                   },
                   {
                       "id":  "audit",
                       "path":  "skills/audit"
                   },
                   {
                       "id":  "tooling",
                       "path":  "skills/tooling"
                   }
               ],
    "hooks":  [
                  {
                      "name":  "visual.capture.requested",
                      "description":  "A deterministic visual capture has been requested for a scenario or review subject.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-feature-delivery",
                                        "ludots-pr-issue-orchestration"
                                    ],
                      "consumers":  [
                                        "ludots-visual-capture",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "visual.capture.completed",
                      "description":  "Visual capture finished and an evidence manifest is ready.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-visual-capture"
                                    ],
                      "consumers":  [
                                        "ludots-video-frame-extract",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "visual.capture.blocked",
                      "description":  "Visual capture could not proceed and the blocker is explicit.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-visual-capture"
                                    ],
                      "consumers":  [
                                        "ludots-cloud-handoff",
                                        "ludots-pr-issue-orchestration",
                                        "ludots-ci-audit-gate",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "visual.frames.ready",
                      "description":  "Frames and contact sheet are ready for visual review.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-video-frame-extract"
                                    ],
                      "consumers":  [
                                        "ludots-visual-review",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "visual.review.completed",
                      "description":  "Visual review completed with a verdict and linked findings.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-visual-review"
                                    ],
                      "consumers":  [
                                        "ludots-feature-delivery",
                                        "ludots-cloud-handoff",
                                        "ludots-pr-issue-orchestration",
                                        "ludots-ci-audit-gate",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "handoff.ready",
                      "description":  "Cloud session handoff packet is complete and ready for the next agent or engineer.",
                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-cloud-handoff"
                                    ],
                      "consumers":  [
                                        "ludots-pr-issue-orchestration",
                                        "ludots-ci-audit-gate",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "pr.packet.ready",
