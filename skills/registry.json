                      "schema":  "skills/contracts/hook.schema.json",
                      "producers":  [
                                        "ludots-ci-audit-gate"
                                    ],
                      "consumers":  [
                                        "ludots-cloud-handoff",
                                        "ludots-pr-issue-orchestration",
                                        "ludots-hook-orchestrator"
                                    ]
                  },
                  {
                      "name":  "visual.frames.blocked",
                      "description":  "Frame extraction could not produce reviewable frames within budget or due to missing prerequisites.",
