{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ludots.local/skills/contracts/evidence-manifest.schema.json",
  "title": "Ludots Evidence Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_id",
    "subject",
    "capture",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{5,127}$"
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "key"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "scenario_id": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "source_hook_packet": {
      "type": "string",
      "pattern": "^artifacts/"
    },
    "capture": {
      "type": "object",
      "required": [
        "kind",
        "tool",
        "started_at_utc",
        "completed_at_utc"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "screenshot",
            "video",
            "frames",
            "contact_sheet",
            "mixed"
          ]
        },
        "tool": {
          "type": "string"
        },
        "requested_by": {
          "type": "string"
        },
        "started_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "screenshot",
              "video",
              "frame",
              "contact_sheet",
              "log",
              "manifest"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^artifacts/"
          },
          "timestamp_ms": {
            "type": "integer",
            "minimum": 0
          },
          "media_type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
