<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>Svg.Custom</AssemblyName>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <Nullable>disable</Nullable>
    <NoWarn>CS1591;SYSLIB0014</NoWarn>
    <DefineConstants>$(DefineConstants);NO_SDC;NETCORE</DefineConstants>
  </PropertyGroup>

  <PropertyGroup>
    <SvgSourcesBasePath>..\externals\SVG</SvgSourcesBasePath>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="$(SvgSourcesBasePath)\Source\Resources\svg11.dtd">
      <Link>Resources\svg11.dtd</Link>
      <LogicalName>Svg.Resources.svg11.dtd</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="bin\**;obj\**" />
    <Compile Include="$(SvgSourcesBasePath)\Source\**\*.cs" Exclude="$(SvgSourcesBasePath)\Source\obj\**" />
    <Compile Remove="$(SvgSourcesBasePath)\Source\Properties\AssemblyInfo.cs" />
    <Compile Remove="$(SvgSourcesBasePath)\Source\Resources\svg11.dtd" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ExCSS\ExCSS.csproj" />
  </ItemGroup>

  <Target Name="BuildSvgGenerators" BeforeTargets="CoreCompile">
    <MSBuild Projects="..\externals\SVG\Generators\Svg.Generators.csproj"
             Targets="Restore;Build"
             Properties="Configuration=$(Configuration)" />
    <ItemGroup>
      <Analyzer Include="..\externals\SVG\Generators\bin\$(Configuration)\net9.0\Svg.Generators.dll" />
    </ItemGroup>
  </Target>
</Project>
